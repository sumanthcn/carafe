{
  "kind": "component",
  "collectionName": "components_elements_order_item",
  "info": {
    "displayName": "Order Item",
    "icon": "shoppingCart",
    "description": "Order line item"
  },
  "options": {},
  "attributes": {
    "productId": {
      "type": "integer"
    },
    "productName": {
      "type": "string",
      "required": true
    },
    "productSlug": {
      "type": "string"
    },
    "sku": {
      "type": "string"
    },
    "quantity": {
      "type": "integer",
      "required": true,
      "min": 1
    },
    "unitPrice": {
      "type": "decimal",
      "required": true
    },
    "totalPrice": {
      "type": "decimal",
      "required": true
    },
    "weight": {
      "type": "string"
    },
    "isSubscription": {
      "type": "boolean",
      "default": false
    },
    "subscriptionInterval": {
      "type": "enumeration",
      "enum": ["1_week", "2_weeks", "3_weeks", "1_month", "2_months"]
    },
    "subscriptionDiscountPercentage": {
      "type": "decimal",
      "min": 0,
      "max": 100
    },
    "originalUnitPrice": {
      "type": "decimal"
    },
    "savingsPerUnit": {
      "type": "decimal"
    }
  }
}
