{
  "name": "Carafe Coffee - Strapi Backend",
  "description": "Strapi CMS backend for Carafe Coffee e-commerce platform",
  "repository": "https://github.com/sumanthcn/carafe",
  "keywords": ["strapi", "cms", "headless", "api"],
  "stack": "container",
  "env": {
    "NODE_ENV": {
      "description": "Node environment",
      "value": "production",
      "required": true
    },
    "HOST": {
      "description": "Server host",
      "value": "0.0.0.0",
      "required": true
    },
    "PORT": {
      "description": "Server port",
      "value": "1337",
      "required": true
    },
    "APP_KEYS": {
      "description": "App keys for Strapi (comma-separated)",
      "generator": "secret",
      "required": true
    },
    "API_TOKEN_SALT": {
      "description": "API token salt",
      "generator": "secret",
      "required": true
    },
    "ADMIN_JWT_SECRET": {
      "description": "Admin JWT secret",
      "generator": "secret",
      "required": true
    },
    "TRANSFER_TOKEN_SALT": {
      "description": "Transfer token salt",
      "generator": "secret",
      "required": true
    },
    "JWT_SECRET": {
      "description": "JWT secret",
      "generator": "secret",
      "required": true
    },
    "DATABASE_CLIENT": {
      "description": "Database client",
      "value": "postgres",
      "required": true
    },
    "DATABASE_HOST": {
      "description": "Database host from Heroku Postgres addon",
      "required": true
    },
    "DATABASE_PORT": {
      "description": "Database port",
      "value": "5432",
      "required": true
    },
    "DATABASE_NAME": {
      "description": "Database name",
      "required": true
    },
    "DATABASE_USERNAME": {
      "description": "Database username",
      "required": true
    },
    "DATABASE_PASSWORD": {
      "description": "Database password",
      "required": true
    },
    "DATABASE_SSL": {
      "description": "Enable SSL for database connection",
      "value": "true",
      "required": true
    },
    "FRONTEND_URL": {
      "description": "Frontend URL for CORS",
      "value": "https://carafe.coffee",
      "required": true
    },
    "PUBLIC_URL": {
      "description": "Public URL of this Strapi instance",
      "required": true
    },
    "STRIPE_SECRET_KEY": {
      "description": "Stripe secret key (sk_live_... for production, sk_test_... for sandbox). Get from https://dashboard.stripe.com/apikeys",
      "required": true
    },
    "STRIPE_WEBHOOK_SECRET": {
      "description": "Stripe webhook signing secret (whsec_...). Register endpoint in Stripe Dashboard > Developers > Webhooks",
      "required": true
    },
    "SMTP_HOST": {
      "description": "SMTP server host for transactional email (e.g. smtpout.secureserver.net for GoDaddy, smtp.office365.com for M365)",
      "required": true
    },
    "SMTP_PORT": {
      "description": "SMTP port – 587 for STARTTLS (recommended) or 465 for SSL/TLS",
      "value": "587",
      "required": true
    },
    "SMTP_USER": {
      "description": "SMTP authentication username (typically the sender email address)",
      "required": true
    },
    "SMTP_PASS": {
      "description": "SMTP authentication password",
      "required": true
    },
    "SMTP_FROM_EMAIL": {
      "description": "From email address shown to recipients. Defaults to SMTP_USER if not set.",
      "required": false
    },
    "EMAIL_FROM_NAME": {
      "description": "Display name in the From header (e.g. Carafe Coffee)",
      "value": "Carafe Coffee",
      "required": false
    }
  },
  "formation": {
    "web": {
      "quantity": 1,
      "size": "standard-1x"
    }
  },
  "addons": [
    {
      "plan": "heroku-postgresql:mini",
      "as": "DATABASE"
    }
  ],
  "buildpacks": [],
  "engines": {
    "node": ">=18.0.0",
    "yarn": ">=1.22.0"
  }
}
