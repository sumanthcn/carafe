# =============================================================================
# HEROKU ENVIRONMENT VARIABLES - NUXT FRONTEND
# =============================================================================
# Copy these to Heroku Config Vars: heroku config:set VAR=value --app your-app

# Node Environment
NODE_ENV=production
HOST=0.0.0.0
PORT=3000

# Public URLs
NUXT_PUBLIC_SITE_URL=https://carafe-frontend.herokuapp.com
NUXT_PUBLIC_STRAPI_URL=https://carafe-strapi.herokuapp.com

# Strapi API Token (Generate in Strapi admin: Settings > API Tokens)
STRAPI_API_TOKEN=your_strapi_api_token_here

# Build Configuration
# Set to "true" only if you want to prerender pages at build time
# Leave unset or "false" for Heroku to avoid build-time Strapi connection errors
ENABLE_PRERENDER=false

# ========================================
# STRIPE PAYMENT GATEWAY
# ========================================
# Publishable (public) key – safe to include in browser bundle
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Analytics (Optional)
# GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X
# FACEBOOK_PIXEL_ID=your_pixel_id
